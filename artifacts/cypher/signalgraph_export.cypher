MERGE (n:Paper {id: "paper:sample:graphrag"}) SET n += {"abstract": "GraphRAG uses entity graphs, community detection, and community reports to improve answers for global questions over a corpus. The method is useful when evidence requires multi-hop relationships across papers, claims, and source chunks.", "arxiv_id": "2404.16130", "citation_count": 128, "confidence": 1.0, "created_at": "2026-06-17T21:58:25+00:00", "extraction_method": "api", "extractor_version": "signalgraph-0.1", "id": "paper:sample:graphrag", "published_at": "2024-04-24", "source_name": "sample", "source_quality_reasons": ["source_type:sample_fixture"], "source_quality_score": 0.8, "source_quality_tier": "medium", "source_quality_type": "sample_fixture", "source_record_id": "source:sample:9b98602d0fee3df4", "source_url": "https://arxiv.org/abs/2404.16130", "title": "From Local to Global: A GraphRAG Approach to Query-Focused Summarization", "venue": "arXiv"};
MERGE (n:Paper {id: "paper:sample:memgpt"}) SET n += {"abstract": "Agent memory systems manage short-term and long-term context for language agents. The approach highlights production risks around memory freshness, retrieval policy, and evaluation of persisted context.", "arxiv_id": "2310.08560", "citation_count": 340, "confidence": 1.0, "created_at": "2026-06-17T21:58:25+00:00", "extraction_method": "api", "extractor_version": "signalgraph-0.1", "id": "paper:sample:memgpt", "published_at": "2023-10-12", "source_name": "sample", "source_quality_reasons": ["source_type:sample_fixture"], "source_quality_score": 0.8, "source_quality_tier": "medium", "source_quality_type": "sample_fixture", "source_record_id": "source:sample:504f3f8521dbd8f9", "source_url": "https://arxiv.org/abs/2310.08560", "title": "MemGPT: Towards LLMs as Operating Systems", "venue": "arXiv"};
MERGE (n:Paper {id: "paper:sample:rag-eval"}) SET n += {"abstract": "RAG evaluation should include faithfulness, answer relevance, context precision, context recall, graph path recall, and evidence-chain completeness. Benchmarks are strongest when they compare vector-only retrieval against graph-aware retrieval.", "citation_count": 42, "confidence": 1.0, "created_at": "2026-06-17T21:58:25+00:00", "extraction_method": "api", "extractor_version": "signalgraph-0.1", "id": "paper:sample:rag-eval", "published_at": "2024-08-01", "source_name": "sample", "source_quality_reasons": ["source_type:sample_fixture"], "source_quality_score": 0.8, "source_quality_tier": "medium", "source_quality_type": "sample_fixture", "source_record_id": "source:sample:ce0cdee458f10057", "source_url": "https://openalex.org/W999999", "title": "RAG Evaluation with Faithfulness and Context Recall", "venue": "OpenAlex sample"};
